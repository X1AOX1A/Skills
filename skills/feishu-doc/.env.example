# Copy to .env (in this skill directory) and fill in. Do NOT commit real secrets.
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# Recipient — set ONE (precedence: open_id > email > mobile)
FEISHU_TO_OPEN_ID=ou_xxxxxxxx        # recommended; how to get: https://open.feishu.cn/document/faq/trouble-shooting/how-to-obtain-openid
# FEISHU_TO_EMAIL=you@example.com
# FEISHU_TO_MOBILE=+8613800138000    # needs contact:user.id:readonly scope

# Optional:
# FEISHU_FOLDER_NAME=PaperSuggess     # save into this folder (created under My Space root if missing)
# FEISHU_FOLDER_TOKEN=fldxxxxxxxxxxxx  # or target a folder by token
# FEISHU_GRANT_PERM=full_access        # add recipient as collaborator: view | edit | full_access (可管理)
# FEISHU_BASE=https://open.feishu.cn
